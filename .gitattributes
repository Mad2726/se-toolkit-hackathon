# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted to native end of line on checkout
*.md text
*.txt text
*.py text eol=lf
*.sh text eol=lf
*.yml text
*.yaml text
*.json text
*.xml text

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.db binary
